{
  "name": "@pb/contracts",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./capability-schemas": "./src/capability-schemas.ts",
    "./version": "./src/version.ts",
    "./core/lib/*": "./src/core/lib/*.ts",
    "./page-builder/background/motion/*": "./src/page-builder/background/motion/*.ts",
    "./page-builder/core/*": "./src/page-builder/core/*.ts",
    "./page-builder/core/page-builder-schemas/*": "./src/page-builder/core/page-builder-schemas/*.ts",
    "./page-builder/core/page-builder-types/*": "./src/page-builder/core/page-builder-types/*.ts"
  },
  "files": [
    "src",
    "dist",
    "fixtures"
  ],
  "scripts": {
    "type-check": "tsc --noEmit -p tsconfig.json",
    "generate-schemas": "tsx scripts/generate-schemas.ts"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
