{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "@pb/contracts/1.0.0/capability-exporter.schema.json",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "const": "exporter"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "inputContractVersions": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "outputTargets": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "fidelityLevel": {
      "type": "string",
      "enum": [
        "lossless",
        "high",
        "medium",
        "low"
      ]
    },
    "diagnosticCodes": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "required": [
    "type",
    "name",
    "version",
    "inputContractVersions",
    "outputTargets",
    "fidelityLevel",
    "diagnosticCodes"
  ],
  "additionalProperties": false
}
