{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "@pb/contracts/1.0.0/capability-cms-adapter.schema.json",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "const": "cmsAdapter"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "cmsProvider": {
      "type": "string",
      "minLength": 1
    },
    "syncModes": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "pull",
          "push",
          "bidirectional"
        ]
      }
    },
    "mappingFeatures": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "conflictPolicies": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "lastWriteWins",
          "manualReview",
          "reject"
        ]
      }
    },
    "diagnosticCodes": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "required": [
    "type",
    "name",
    "version",
    "cmsProvider",
    "syncModes",
    "mappingFeatures",
    "conflictPolicies",
    "diagnosticCodes"
  ],
  "additionalProperties": false
}
