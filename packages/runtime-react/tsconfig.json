{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "react-jsx",
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["node", "react"],
    "paths": {
      "@pb/runtime-react/*": ["./src/*"],
      "@/page-builder/*": ["./src/page-builder/*"],
      "@/core/*": ["./src/core/*"],
      "@/content/*": ["./src/content/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
