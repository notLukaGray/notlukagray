{
  "type": "contentBlock",
  "flexDirection": "column",
  "id": "form_demo_intro",
  "ariaLabel": "Form demo intro",
  "width": ["100%", "92%"],
  "height": "hug",
  "align": ["full", "center"],
  "fill": "#1a1a1a",
  "borderRadius": ["1.5rem 1.5rem 0 0", "2rem 2rem 0 0"],
  "elementOrder": ["intro-heading", "intro-body"],
  "effects": [
    {
      "type": "backdropBlur",
      "amount": "16px"
    }
  ],
  "definitions": {
    "intro-heading": {
      "type": "elementHeading",
      "level": 1,
      "text": "Form fields demo",
      "align": "center",
      "width": "hug",
      "wordWrap": true,
      "marginTop": "2rem",
      "marginBottom": "0.5rem"
    },
    "intro-body": {
      "type": "elementBody",
      "level": 2,
      "text": "All form field types appear below, with a content block above. Labels and inputs use the same level-based typography as elements; you can override with labelClassName and inputClassName in JSON.",
      "align": "center",
      "textAlign": "center",
      "width": ["90%", "70%"],
      "wordWrap": true,
      "marginBottom": "2rem"
    }
  },
  "gap": "1rem"
}
