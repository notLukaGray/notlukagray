        "background": "#2a2a2a",
        "borderRadius": "8px",
        "cursor": "grab",
        "userSelect": "none"
      }
    },
    "reorder-item-3": {
      "type": "elementBody",
      "level": 2,
      "text": "3. Third item",
      "align": "center",
