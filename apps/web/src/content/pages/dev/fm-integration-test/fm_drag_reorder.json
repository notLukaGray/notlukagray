      "type": "elementHeading",
      "level": 2,
      "text": "Drag to reorder",
      "align": "center",
      "width": "hug",
      "wordWrap": true,
      "marginTop": "1.5rem",
      "marginBottom": "1rem"
    },
    "reorder-item-1": {
