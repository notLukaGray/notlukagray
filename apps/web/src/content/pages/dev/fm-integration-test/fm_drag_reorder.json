{
  "type": "contentBlock",
  "flexDirection": "column",
  "id": "fm_drag_reorder",
  "ariaLabel": "Drag to reorder list",
  "width": ["100%", "88%"],
  "height": "hug",
  "align": ["full", "center"],
  "fill": "#050509",
  "borderRadius": "1rem",
  "marginTop": "1rem",
  "marginBottom": "1rem",
  "reorderable": true,
  "elementOrder": [
    "reorder-title",
    "reorder-item-1",
    "reorder-item-2",
    "reorder-item-3",
    "reorder-item-4",
    "reorder-hint"
  ],
  "definitions": {
