      "level": 2,
      "text": "1. First item",
      "align": "center",
      "textAlign": "center",
      "width": "hug",
      "wordWrap": true,
      "marginBottom": "0.5rem",
      "wrapperStyle": {
        "padding": "12px 16px",
        "maxWidth": "480px",
        "margin": "0 auto",
        "background": "#252525",
        "borderRadius": "8px",
        "cursor": "grab",
        "userSelect": "none"
      }
    },
    "reorder-item-2": {
      "type": "elementBody",
