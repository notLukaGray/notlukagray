{
  "type": "contentBlock",
  "flexDirection": "column",
  "id": "glass_temp_showcase",
  "ariaLabel": "glass_temp_showcase",
  "width": ["100%", "92%"],
  "height": "hug",
  "align": ["full", "center"],
  "fill": "linear-gradient(rgba(138,180,255,0.08) 1px, transparent 1px) 0 0/36px 36px, linear-gradient(90deg, rgba(138,180,255,0.08) 1px, transparent 1px) 0 0/36px 36px, radial-gradient(130% 120% at 0% 0%, #1f2d43 0%, #111827 45%, #07090f 100%)",
  "borderRadius": "1.5rem",
  "marginTop": "1rem",
  "marginBottom": "2rem",
  "motion": {
    "initial": {
      "opacity": 0,
      "y": 24
    },
    "animate": {
      "opacity": 1,
      "y": 0
    },
    "transition": {
      "duration": 0.55,
      "ease": [0.22, 1, 0.36, 1]
    }
  },
  "elementOrder": [
    "title",
    "subtitle",
    "search-input",
    "switch-glass",
    "slider-glass",
    "magnifier-scene",
    "magnifier-glass",
    "drag-state-label",
    "drag-state-value"
  ],
  "definitions": {
    "title": {
      "type": "elementHeading",
      "level": 2,
      "text": "Liquid Glass Lab (Temp-style)",
      "align": "center",
      "width": "hug",
      "marginTop": "1.5rem",
      "marginBottom": "0.4rem",
      "motionTiming": {
        "entrancePreset": "fade",
        "entranceMotion": {
          "transition": {
            "duration": 0.4
          }
        }
      }
    },
    "subtitle": {
      "type": "elementBody",
      "level": 2,
      "text": "Searchbox, switch, slider, and magnifier optics. Drag each glass surface to test live refraction against high-contrast backdrops.",
      "align": "center",
      "textAlign": "center",
      "width": ["92%", "72%"],
      "marginBottom": "1rem",
      "motionTiming": {
        "entrancePreset": "slideUp",
        "entranceMotion": {
          "transition": {
            "duration": 0.42,
            "delay": 0.06
          }
        }
      }
    },
    "search-input": {
      "type": "elementInput",
      "placeholder": "Search",
      "ariaLabel": "Search glass lab",
      "showIcon": true,
      "width": "420px",
      "height": "56px",
      "borderRadius": "28px",
      "align": "center",
      "zIndex": 4,
      "marginBottom": "0.9rem",
      "wrapperStyle": {
        "position": "relative",
        "zIndex": 30
      },
      "motion": {
        "initial": {
          "opacity": 0,
          "y": 18
        },
        "whileInView": {
          "opacity": 1,
          "y": 0
        },
        "whileHover": {
          "scale": 1.02
        },
        "whileFocus": {
          "scale": 1.02
        },
        "whileTap": {
          "scale": 0.995
        },
        "transition": {
          "type": "spring",
          "stiffness": 240,
          "damping": 24
        },
        "viewport": {
          "once": true,
          "amount": 0.2
        }
      },
      "effects": [
        {
          "type": "glass",
          "bezelType": "convex_squircle",
          "bezelWidth": 27,
          "glassThickness": 70,
          "refractiveIndex": 1.5,
          "blur": 1,
          "scaleRatio": 0.7,
          "dispersion": 1,
          "specularOpacity": 1,
          "specularSaturation": 4,
          "magnifyingScale": 0,
          "dropShadow": true
        }
      ]
    },
    "switch-glass": {
      "type": "elementSVG",
      "markup": "<svg width=\"160\" height=\"92\" viewBox=\"0 0 160 92\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><rect x=\"0\" y=\"12\" width=\"160\" height=\"67\" rx=\"33.5\" fill=\"black\" fill-opacity=\"0.01\"/><rect x=\"7\" y=\"0\" width=\"146\" height=\"92\" rx=\"46\" fill=\"black\" fill-opacity=\"0.01\"/></svg>",
      "ariaLabel": "Switch glass",
      "width": "160px",
      "height": "92px",
      "borderRadius": "46px",
      "align": "center",
      "zIndex": 4,
      "marginBottom": "1rem",
      "wrapperStyle": {
        "position": "relative",
        "zIndex": 30
      },
      "motion": {
        "initial": {
          "opacity": 0,
          "y": 18,
          "zIndex": 30
        },
        "whileInView": {
          "opacity": 1,
          "y": 0,
          "zIndex": 30
        },
        "whileHover": {
          "y": -1,
          "zIndex": 90
        },
        "whileTap": {
          "zIndex": 90
        },
        "drag": "x",
        "dragConstraints": {
          "left": -120,
          "right": 120
        },
        "dragElastic": 0.2,
        "dragMomentum": true,
        "whileDrag": {
          "scale": 1.04,
          "zIndex": 95
        },
        "transition": {
          "type": "spring",
          "stiffness": 260,
          "damping": 26
        },
        "viewport": {
          "once": true,
          "amount": 0.2
        }
      },
      "effects": [
        {
          "type": "glass",
          "bezelType": "lip",
          "bezelWidth": 19,
          "glassThickness": 47,
          "dispersion": 1,
          "refractiveIndex": 1.5,
          "blur": 0.2,
          "scaleRatio": 0.9,
          "specularOpacity": 0.5,
          "specularSaturation": 6,
          "magnifyingScale": 0,
          "dropShadow": true
        }
      ]
    },
    "slider-glass": {
      "type": "elementRange",
      "ariaLabel": "Slider control",
      "min": 0,
      "max": 100,
      "step": 1,
      "defaultValue": 28,
      "width": "332px",
      "height": "60px",
      "borderRadius": "30px",
      "align": "center",
      "zIndex": 4,
      "marginBottom": "1rem",
      "wrapperStyle": {
        "position": "relative",
        "zIndex": 30
      },
      "style": {
        "trackColor": "#89898F66",
        "fillColor": "#0377F7",
        "trackHeight": "14px",
        "thumbSize": "60px",
        "thumbWidth": "90px",
        "borderRadius": "9999px",
        "glassOnThumb": "true",
        "thumbIdleScale": 0.6,
        "thumbActiveScale": 1,
        "thumbIdleOpacity": 1,
        "thumbActiveOpacity": 0.1
      },
      "motion": {
        "initial": {
          "opacity": 0,
          "y": 14,
          "zIndex": 30
        },
        "whileInView": {
          "opacity": 1,
          "y": 0,
          "zIndex": 30
        },
        "whileHover": {
          "scale": 1.015,
          "zIndex": 90
        },
        "whileTap": {
          "zIndex": 90
        },
        "transition": {
          "type": "spring",
          "stiffness": 260,
          "damping": 28
        },
        "viewport": {
          "once": true,
          "amount": 0.2
        }
      },
      "effects": [
        {
          "type": "glass",
          "bezelType": "lip",
          "bezelWidth": 19,
          "glassThickness": 47,
          "refractiveIndex": 1.5,
          "blur": 0.2,
          "scaleRatio": 0.9,
          "specularOpacity": 0.5,
          "specularSaturation": 6,
          "magnifyingScale": 0,
          "dropShadow": true
        }
      ]
    },
    "magnifier-scene": {
      "type": "elementSVG",
      "markup": "<svg width=\"420\" height=\"200\" viewBox=\"0 0 420 200\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><circle cx=\"210\" cy=\"75\" r=\"24\" stroke=\"#34D399\" stroke-width=\"2.5\" opacity=\"0.85\"/><circle cx=\"210\" cy=\"75\" r=\"52\" stroke=\"#34D399\" stroke-width=\"1.5\" opacity=\"0.55\"/><circle cx=\"210\" cy=\"75\" r=\"88\" stroke=\"#34D399\" stroke-width=\"1\" opacity=\"0.28\"/><circle cx=\"210\" cy=\"75\" r=\"5\" fill=\"#34D399\" opacity=\"0.95\"/><polyline points=\"0,75 5,86 10,94 15,97 20,94 25,86 30,75 35,64 40,56 45,53 50,56 55,64 60,75 65,86 70,94 75,97 80,94 85,86 90,75 95,64 100,56 105,53 110,56 115,64 120,75 125,86 130,94 135,97 140,94 145,86 150,75 155,64 160,56 165,53 170,56 175,64 180,75 185,86 190,94 195,97 200,94 205,86 210,75 215,64 220,56 225,53 230,56 235,64 240,75 245,86 250,94 255,97 260,94 265,86 270,75 275,64 280,56 285,53 290,56 295,64 300,75 305,86 310,94 315,97 320,94 325,86 330,75 335,64 340,56 345,53 350,56 355,64 360,75 365,86 370,94 375,97 380,94 385,86 390,75 395,64 400,56 405,53 410,56 415,64 420,75\" stroke=\"#F472B6\" stroke-width=\"2.5\" opacity=\"0.75\"/><circle cx=\"80\" cy=\"36\" r=\"16\" fill=\"#3B82F6\" fill-opacity=\"0.35\"/><circle cx=\"344\" cy=\"148\" r=\"20\" fill=\"#8B5CF6\" fill-opacity=\"0.32\"/></svg>",
      "ariaLabel": "Magnifier vector scene",
      "width": "420px",
      "height": "200px",
      "borderRadius": "24px",
      "align": "center",
      "zIndex": 1,
      "marginBottom": "-200px"
    },
    "magnifier-glass": {
      "type": "elementSVG",
      "markup": "<svg width=\"210\" height=\"150\" viewBox=\"0 0 210 150\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><rect width=\"210\" height=\"150\" rx=\"75\" fill=\"black\" fill-opacity=\"0.01\"/></svg>",
      "ariaLabel": "Magnifier glass",
      "width": "210px",
      "height": "150px",
      "borderRadius": "75px",
      "align": "center",
      "zIndex": 4,
      "marginBottom": "0.8rem",
      "wrapperStyle": {
        "position": "relative",
        "zIndex": 30
      },
      "interactions": {
        "onPointerDown": {
          "type": "setVariable",
          "payload": {
            "key": "glass.dragging",
            "value": "dragging"
          }
        },
        "onPointerUp": {
          "type": "setVariable",
          "payload": {
            "key": "glass.dragging",
            "value": "idle"
          }
        },
        "cursor": "grab"
      },
      "motion": {
        "initial": {
          "opacity": 0,
          "scale": 0.94,
          "zIndex": 30
        },
        "whileInView": {
          "opacity": 1,
          "scale": 1,
          "zIndex": 30
        },
        "whileHover": {
          "y": -1,
          "zIndex": 90
        },
        "whileTap": {
          "zIndex": 90
        },
        "drag": true,
        "dragConstraints": {
          "left": -96,
          "right": 96,
          "top": -54,
          "bottom": 54
        },
        "dragElastic": 0.13,
        "dragMomentum": false,
        "whileDrag": {
          "scale": 1.05,
          "zIndex": 95
        },
        "transition": {
          "type": "spring",
          "stiffness": 260,
          "damping": 24
        },
        "viewport": {
          "once": true,
          "amount": 0.2
        }
      },
      "effects": [
        {
          "type": "glass",
          "bezelType": "convex_squircle",
          "bezelWidth": 27,
          "glassThickness": 70,
          "refractiveIndex": 1.5,
          "blur": 4,
          "dispersion": 1,
          "scaleRatio": 1,
          "specularOpacity": 1,
          "specularSaturation": 9,
          "magnifyingScale": 1,
          "dropShadow": false
        }
      ]
    },
    "drag-state-label": {
      "type": "elementBody",
      "level": 2,
      "text": "Drag state variable:",
      "align": "center",
      "textAlign": "center",
      "width": "hug",
      "marginBottom": "0.2rem",
      "color": "rgba(255, 255, 255, 0.72)"
    },
    "drag-state-value": {
      "type": "elementBody",
      "level": 2,
      "text": "idle",
      "variableKey": "glass.dragging",
      "align": "center",
      "textAlign": "center",
      "width": "hug",
      "marginBottom": "1.2rem",
      "color": "rgba(255, 255, 255, 0.95)"
    }
  },
  "gap": "1rem"
}
