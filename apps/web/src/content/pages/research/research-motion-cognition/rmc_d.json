{
  "type": "contentBlock",
  "flexDirection": "column",
  "id": "rmc_d",
  "width": ["100%", "72%"],
  "height": "hug",
  "align": "center",
  "fill": "#00000000",
  "marginBottom": ["1.5rem", "2.5rem"],
  "padding": ["1.5rem 1rem", "0"],
  "elementOrder": ["d-label", "d-principle", "d-footnote"],
  "definitions": {
    "d-label": {
      "type": "elementHeading",
      "level": 6,
      "text": "CENTRAL PRINCIPLE",
      "align": "center",
      "width": "hug",
      "height": "hug",
      "marginBottom": "1.5rem",
      "motionTiming": {
        "entrancePreset": "fade",
        "viewport": {
          "amount": 0.3
        },
        "entranceMotion": {
          "transition": {
            "duration": 0.4,
            "delay": 0
          }
        }
      }
    },
    "d-principle": {
      "type": "elementHeading",
      "level": 2,
      "text": "Motion earns its existence by reducing the work the user must do to understand what changed, where they are, and what comes next.",
      "align": "center",
      "textAlign": "center",
      "width": "100%",
      "height": "hug",
      "wordWrap": true,
      "motionTiming": {
        "entrancePreset": "fade",
        "viewport": {
          "amount": 0.3
        },
        "entranceMotion": {
          "transition": {
            "duration": 0.7,
            "delay": 0.15
          }
        }
      }
    },
    "d-footnote": {
      "type": "elementBody",
      "level": 4,
      "text": "Every animation that is added without a clear cognitive rationale is a tax on the user's attention. The fact that it looks good is not sufficient justification.",
      "align": "center",
      "textAlign": "center",
      "width": "100%",
      "height": "hug",
      "wordWrap": true,
      "motionTiming": {
        "entrancePreset": "fade",
        "viewport": {
          "amount": 0.3
        },
        "entranceMotion": {
          "transition": {
            "duration": 0.5,
            "delay": 0.35
          }
        }
      }
    }
  },
  "gap": "1rem"
}
