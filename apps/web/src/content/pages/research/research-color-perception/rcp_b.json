{
  "type": "sectionColumn",
  "id": "rcp_b",
  "width": ["100%", "90%"],
  "height": "hug",
  "align": ["full", "center"],
  "fill": "oklch(from var(--pb-on-secondary) l c h / 0.024)",
  "borderRadius": ["1.25rem", "2rem"],
  "effects": [{ "type": "backdropBlur", "amount": "12px" }],
  "marginBottom": ["1.5rem", "2.5rem"],
  "columns": { "mobile": 1, "desktop": 2 },
  "columnWidths": { "mobile": [1], "desktop": [1, 1.3] },
  "columnGaps": { "mobile": "0.75rem", "desktop": "1.5rem" },
  "columnStyles": {
    "mobile": [{ "padding": "1.25rem", "gap": "1rem" }],
    "desktop": [
      { "padding": "1.75rem", "gap": "1rem" },
      { "padding": "1.75rem", "gap": "1rem" }
    ]
  },
  "itemStyles": {
    "desktop": {
      "b-demo": {
        "borderRadius": "1.25rem",
        "fill": "oklch(from var(--pb-on-secondary) l c h / 0.020)",
        "padding": "0.4rem"
      }
    }
  },
  "columnAssignments": {
    "mobile": { "b-kicker": 0, "b-hypothesis": 0, "b-approach": 0, "b-demo": 0 },
    "desktop": { "b-kicker": 0, "b-hypothesis": 0, "b-approach": 0, "b-demo": 1 }
  },
  "elementOrder": ["b-kicker", "b-hypothesis", "b-approach", "b-demo"],
  "definitions": {
    "b-kicker": {
      "type": "elementHeading",
      "level": 6,
      "text": "FRAMEWORK",
      "align": "left",
      "width": "hug",
      "height": "hug"
    },
    "b-hypothesis": {
      "type": "elementHeading",
      "level": 3,
      "text": "A color value does not contain its meaning. That meaning is produced in context.",
      "align": "left",
      "textAlign": "left",
      "width": "100%",
      "height": "hug",
      "wordWrap": true,
      "motionTiming": {
        "entrancePreset": "slideUp",
        "viewport": { "amount": 0.2 },
        "entranceMotion": { "transition": { "duration": 0.5, "delay": 0 } }
      }
    },
    "b-approach": {
      "type": "elementRichText",
      "content": "This paper examines three principal mechanisms:\n\n**1. Simultaneous contrast** — how adjacent hues shift each other's apparent value and saturation\n\n**2. Luminance relativity** — how the same lightness reads differently against dark versus light fields\n\n**3. Cultural framing** — how a given hue carries different emotional valence across linguistic and cultural communities\n\nEach mechanism has direct consequences for palette construction, accessibility, and cross-market design.",
      "level": 4,
      "align": "left",
      "width": "100%",
      "height": "hug",
      "wordWrap": true,
      "motionTiming": {
        "entrancePreset": "fade",
        "viewport": { "amount": 0.2 },
        "entranceMotion": { "transition": { "duration": 0.5, "delay": 0.1 } }
      }
    },
    "b-demo": {
      "type": "elementImage",
      "src": "research/research-color-perception/color-contrast-demo.webp",
      "alt": "Simultaneous contrast demonstration — identical swatches on dark and light grounds",
      "objectFit": "contain",
      "width": "100%",
      "height": ["14rem", "100%"],
      "constraints": [{ "minHeight": "0" }, { "minHeight": "18rem" }],
      "borderRadius": ["0.75rem", "1rem"],
      "align": "center",
      "motionTiming": {
        "entrancePreset": "fade",
        "viewport": { "amount": 0.2 },
        "entranceMotion": { "transition": { "duration": 0.5, "delay": 0.05 } }
      }
    }
  }
}
