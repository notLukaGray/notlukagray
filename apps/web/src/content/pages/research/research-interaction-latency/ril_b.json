  "borderRadius": ["1.25rem", "2rem"],
  "marginBottom": ["1.5rem", "2.5rem"],
  "columns": {
    "mobile": 1,
    "desktop": 4
  },
  "columnWidths": {
    "mobile": [1],
    "desktop": [1, 1, 1, 1]
  },
