{
  "type": "sectionColumn",
  "id": "ril_c",
  "width": ["100%", "90%"],
  "height": "hug",
  "align": ["full", "center"],
  "fill": "oklch(from var(--pb-on-secondary) l c h / 0.024)",
  "borderRadius": ["1.25rem", "2rem"],
  "marginBottom": ["1.5rem", "2.5rem"],
  "columns": { "mobile": 1, "desktop": 2 },
  "columnWidths": { "mobile": [1], "desktop": [1.1, 1] },
  "columnGaps": { "mobile": "0.75rem", "desktop": "1.25rem" },
  "columnStyles": {
    "mobile": [{ "padding": "1.25rem", "gap": "1rem" }],
    "desktop": [
      { "padding": "1.5rem", "gap": "1rem" },
      { "padding": "1.5rem", "gap": "1rem" }
    ]
  },
  "itemStyles": {
    "desktop": {
      "c-chart": {
        "borderRadius": "1rem",
        "fill": "oklch(from var(--pb-on-secondary) l c h / 0.024)",
        "padding": "0.4rem"
      }
    }
  },
  "columnAssignments": {
    "mobile": { "c-label": 0, "c-study": 0, "c-result": 0, "c-chart": 0 },
    "desktop": { "c-label": 0, "c-study": 0, "c-result": 0, "c-chart": 1 }
  },
  "elementOrder": ["c-label", "c-study", "c-result", "c-chart"],
  "definitions": {
    "c-label": {
      "type": "elementHeading",
      "level": 6,
      "text": "FINDINGS — PERCEIVED VS. ACTUAL LATENCY",
      "align": "left",
      "width": "hug",
      "height": "hug"
    },
    "c-study": {
      "type": "elementBody",
      "level": 3,
      "text": "Users consistently underestimate latency when given accurate progress feedback — and overestimate it when given none.",
      "align": "left",
      "textAlign": "left",
      "width": "100%",
      "height": "hug",
      "wordWrap": true,
      "motionTiming": {
        "entrancePreset": "slideUp",
        "viewport": { "amount": 0.2 },
        "entranceMotion": { "transition": { "duration": 0.5, "delay": 0 } }
      }
    },
    "c-result": {
      "type": "elementRichText",
      "content": "A study comparing four feedback conditions for a 2-second loading state found:\n\n| Condition | Perceived wait |\n|---|---|\n| No feedback | 3.4 seconds |\n| Spinner | 2.8 seconds |\n| Progress bar (determinate) | 2.0 seconds |\n| Skeleton screen | 1.6 seconds |\n\nThe skeleton screen's effect is not speed — it is perception management. By showing the shape of what is coming, it occupies the user's visual parsing system during the wait, making the wait feel productive rather than empty.",
      "level": 4,
      "align": "left",
      "width": "100%",
      "height": "hug",
      "wordWrap": true,
      "motionTiming": {
        "entrancePreset": "fade",
        "viewport": { "amount": 0.2 },
        "entranceMotion": { "transition": { "duration": 0.5, "delay": 0.1 } }
      }
    },
    "c-chart": {
      "type": "elementImage",
      "src": "research/research-interaction-latency/latency-perception-chart.webp",
      "alt": "Chart showing perceived latency vs. actual latency across four feedback conditions",
      "objectFit": "contain",
      "width": "100%",
      "height": ["14rem", "100%"],
      "constraints": [{ "minHeight": "0" }, { "minHeight": "18rem" }],
      "borderRadius": ["0.75rem", "1rem"],
      "align": "center",
      "motionTiming": {
        "entrancePreset": "fade",
        "viewport": { "amount": 0.2 },
        "entranceMotion": { "transition": { "duration": 0.4, "delay": 0.05 } }
      }
    }
  }
}
