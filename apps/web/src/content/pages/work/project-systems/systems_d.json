      "textAlign": "center",
      "width": "100%",
      "height": "hug",
      "wordWrap": true,
      "motionTiming": {
        "entrancePreset": "fade",
        "viewport": {
          "amount": 0.3
        },
        "entranceMotion": {
          "transition": {
            "duration": 0.7,
            "delay": 0.15
          }
        }
      }
    },
    "d-footnote": {
      "type": "elementBody",
      "level": 4,
      "text": "Built for a team of four. Scaled to an org of forty. Documented so anyone could inherit it on day one.",
      "align": "center",
      "textAlign": "center",
      "width": "100%",
      "height": "hug",
      "wordWrap": true,
      "motionTiming": {
        "entrancePreset": "fade",
        "viewport": {
          "amount": 0.3
        },
        "entranceMotion": {
          "transition": {
            "duration": 0.5,
            "delay": 0.35
          }
        }
      }
    }
