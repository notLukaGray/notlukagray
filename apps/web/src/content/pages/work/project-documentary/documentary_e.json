    },
    "e-press": {
      "type": "elementRichText",
      "content": "### Press\n\n\"A film of sustained and quiet attention. Gray has made something that asks for the same patience from its audience that the landscape demands of those who live within it.\"\n— *DocAlliance Review*\n\n\"Unhurried, beautiful, and quietly devastating.\"\n— *Hot Docs Blog*\n\n\"One of the most formally assured debuts of the year.\"\n— *Filmmaker Magazine*",
      "level": 4,
      "align": "left",
      "width": "100%",
      "height": "hug",
      "wordWrap": true,
      "motionTiming": {
        "entrancePreset": "slideUp",
        "viewport": {
          "amount": 0.2
        },
        "entranceMotion": {
          "transition": {
            "duration": 0.4,
            "delay": 0.08
          }
        }
      }
    },
    "e-credits": {
      "type": "elementRichText",
      "content": "### Credits\n\n**Director** Luka Gray\n\n**DoP** Ana Ferreira\n\n**Sound** Paulo Cunha\n\n**Editor** Luka Gray\n\n**Colorist** Dominique Remy\n\n**Producer** Slow River Films\n\n**Co-produced with** RTP / ARTE",
      "level": 5,
      "align": "left",
      "width": "100%",
      "height": "hug",
