{
  "type": "sectionColumn",
  "id": "editorial_d",
  "width": ["100%", "88%"],
  "height": "hug",
  "align": ["full", "center"],
  "fill": "oklch(from var(--pb-on-secondary) l c h / 0.024)",
  "borderRadius": ["1.25rem", "2rem"],
  "effects": [
    { "type": "backdropBlur", "amount": "14px" },
    { "type": "dropShadow", "y": "8px", "blur": "40px", "color": "rgba(0,0,0,0.3)" }
  ],
  "marginBottom": ["2rem", "3rem"],
  "columns": { "mobile": 1, "desktop": 2 },
  "columnWidths": { "mobile": [1], "desktop": [1, 1.2] },
  "columnGaps": { "mobile": "1rem", "desktop": "1.5rem" },
  "columnStyles": {
    "mobile": [{ "padding": "1.5rem", "gap": "1.25rem" }],
    "desktop": [
      { "padding": "2rem 1.5rem", "gap": "1.25rem" },
      { "padding": "2rem 1.5rem", "gap": "1rem" }
    ]
  },
  "elementOrder": ["d-phase-label", "d-process", "d-image-a", "d-image-b", "d-caption"],
  "columnAssignments": {
    "mobile": {
      "d-phase-label": 0,
      "d-process": 0,
      "d-image-a": 0,
      "d-image-b": 0,
      "d-caption": 0
    },
    "desktop": {
      "d-phase-label": 0,
      "d-process": 0,
      "d-image-a": 1,
      "d-image-b": 1,
      "d-caption": 0
    }
  },
  "definitions": {
    "d-phase-label": {
      "type": "elementHeading",
      "level": 6,
      "text": "PROCESS",
      "align": "left",
      "width": "hug",
      "height": "hug",
      "marginBottom": "0.75rem"
    },
    "d-process": {
      "type": "elementRichText",
      "content": "### Research\n\nStarted by auditing the existing system and identifying where it was fighting the content rather than serving it.\n\n### Concept\n\nTwo or three distinct directions, stress-tested at actual publication size before any refinement.\n\n### Production\n\nWorked directly in the production file from week two. No separation between design and preparation for print.",
      "level": 4,
      "align": "left",
      "textAlign": "left",
      "width": "100%",
      "height": "hug",
      "wordWrap": true
    },
    "d-image-a": {
      "type": "elementImage",
      "src": "work/project-editorial/process-a.webp",
      "alt": "Process detail",
      "objectFit": "cover",
      "width": "100%",
      "height": ["16rem", "20rem"],
      "borderRadius": "1rem",
      "align": "center"
    },
    "d-image-b": {
      "type": "elementImage",
      "src": "work/project-editorial/process-b.webp",
      "alt": "Process detail",
      "objectFit": "cover",
      "width": "100%",
      "height": ["12rem", "14rem"],
      "borderRadius": "1rem",
      "align": "center"
    },
    "d-caption": {
      "type": "elementBody",
      "level": 5,
      "text": "The decision to use a modular grid came from the content requirements, not a formal preference. Every issue has different proportions; the grid had to flex.",
      "align": "left",
      "textAlign": "left",
      "width": "100%",
      "height": "hug",
      "wordWrap": true
    }
  }
}
