{
  "type": "sectionColumn",
  "id": "cinematic_d",
  "width": ["100%", "80%"],
  "height": "hug",
  "align": ["full", "center"],
  "fill": "oklch(from var(--pb-secondary) l c h / 0.46)",
  "borderRadius": ["1.5rem", "2rem"],
  "effects": [{ "type": "backdropBlur", "amount": "20px" }],
  "marginBottom": ["2rem", "3rem"],
  "columns": { "mobile": 1, "desktop": 2 },
  "columnWidths": { "mobile": [1], "desktop": [1, 1.4] },
  "columnGaps": { "mobile": "0", "desktop": "0" },
  "columnStyles": {
    "mobile": [{ "padding": "1.5rem", "gap": "1.25rem" }],
    "desktop": [
      { "padding": "2rem", "gap": "1.25rem", "alignY": "center" },
      { "padding": "0.5rem", "gap": "0" }
    ]
  },
  "elementOrder": ["d-kicker", "d-statement", "d-note", "d-still-1", "d-still-2"],
  "columnAssignments": {
    "mobile": { "d-kicker": 0, "d-statement": 0, "d-note": 0, "d-still-1": 0, "d-still-2": 0 },
    "desktop": { "d-kicker": 0, "d-statement": 0, "d-note": 0, "d-still-1": 1, "d-still-2": 1 }
  },
  "definitions": {
    "d-kicker": {
      "type": "elementHeading",
      "level": 6,
      "text": "DIRECTOR'S NOTE",
      "align": "left",
      "width": "hug",
      "height": "hug"
    },
    "d-statement": {
      "type": "elementBody",
      "level": 1,
      "text": "The idea arrived as a feeling before it was a concept — a texture of light on a specific surface at a specific hour. Everything else was built around getting back to that moment with a camera.",
      "align": "left",
      "textAlign": "left",
      "width": "100%",
      "height": "hug",
      "wordWrap": true,
      "motionTiming": {
        "entrancePreset": "slideRight",
        "viewport": { "amount": 0.3 },
        "entranceMotion": { "transition": { "duration": 0.55 } }
      }
    },
    "d-note": {
      "type": "elementBody",
      "level": 4,
      "text": "Shot on location over four days. The crew was three people. Most of the decisions were made by the light.",
      "align": "left",
      "textAlign": "left",
      "width": "100%",
      "height": "hug",
      "wordWrap": true
    },
    "d-still-1": {
      "type": "elementImage",
      "src": "work/project-cinematic/still-1.webp",
      "alt": "Production still",
      "objectFit": "cover",
      "width": "100%",
      "height": ["18rem", "22rem"],
      "align": "center"
    },
    "d-still-2": {
      "type": "elementImage",
      "src": "work/project-cinematic/still-2.webp",
      "alt": "Production still",
      "objectFit": "cover",
      "width": "100%",
      "height": ["14rem", "16rem"],
      "align": "center"
    }
  }
}
