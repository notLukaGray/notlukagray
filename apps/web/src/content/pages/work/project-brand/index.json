{
  "title": "NOMA — Brand Identity",
  "description": "Full brand identity for NOMA, a small-batch Norwegian aquavit distillery — mark, type, colour, and guidelines from first principles.",
  "ogImage": "https://media.notlukagray.com/website/work/project-brand/og.webp",
  "assetBaseUrl": "/work",
  "tags": {
    "brand": ["NOMA"],
    "ability": ["Brand Identity"]
  },
  "sectionOrder": ["brand_a", "brand_b", "brand_c", "brand_d", "brand_e"],
  "bgKey": "bg-brand",
  "definitions": {
    "bg-brand": {
      "type": "backgroundVariable",
      "layers": [
        {
          "fill": "var(--pb-secondary)"
        },
        {
          "fill": {
            "light": "linear-gradient(135deg, #d4eef8 0%, transparent 50%)",
            "dark": "linear-gradient(135deg, #001c2a 0%, transparent 50%)"
          },
          "blendMode": "screen"
        }
      ]
    },
    "bg-brand-accent": {
      "type": "backgroundVariable",
      "layers": [
        {
          "fill": "var(--pb-secondary)"
        },
        {
          "fill": {
            "light": "radial-gradient(ellipse 100% 80% at 50% 50%, #ffe0eb 0%, transparent 70%)",
            "dark": "radial-gradient(ellipse 100% 80% at 50% 50%, #2a0015 0%, transparent 70%)"
          },
          "blendMode": "screen"
        }
      ]
    }
  },
  "transitions": [
    {
      "type": "SCROLL",
      "source": "trigger",
      "id": "brand-accent-reveal",
      "from": "bg-brand",
      "to": "bg-brand-accent"
    }
  ]
}
