{
  "type": "divider",
  "width": "100%",
  "height": ["70vh", "80vh"],
  "align": "full",
  "layers": [
    {
      "fill": {
        "light": "linear-gradient(180deg, transparent 60%, #f6f2f3 100%)",
        "dark": "linear-gradient(180deg, transparent 60%, #0e0b0c 100%)"
      }
    }
  ],
  "onViewportProgress": {
    "type": "updateTransitionProgress",
    "payload": { "id": "photo-to-dark", "invert": true }
  }
}
