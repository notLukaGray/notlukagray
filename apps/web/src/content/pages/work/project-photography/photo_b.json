{
  "type": "contentBlock",
  "flexDirection": "column",
  "id": "photo_b",
  "width": ["100%", "88%"],
  "height": "hug",
  "align": ["full", "center"],
  "fill": "oklch(from var(--pb-secondary) l c h / 0.5)",
  "borderRadius": ["2rem 2rem 0 0", "3rem 3rem 0 0"],
  "effects": [
    {
      "type": "backdropBlur",
      "amount": "24px"
    }
  ],
  "elementOrder": ["b-location", "b-title", "b-medium"],
  "definitions": {
    "b-location": {
      "type": "elementHeading",
      "level": 6,
      "text": "LOCATION · YEAR",
      "align": "center",
      "width": "hug",
      "marginTop": "2.5rem",
      "marginBottom": "1rem",
      "motionTiming": {
        "entrancePreset": "fade",
        "viewport": {
          "amount": 0
        },
        "entranceMotion": {
          "transition": {
            "duration": 0.5
          }
        }
      }
    },
    "b-title": {
      "type": "elementHeading",
      "level": 1,
      "text": "Series Title",
      "align": "center",
      "width": ["90%", "65%"],
      "wordWrap": true,
      "marginBottom": "1rem",
      "motionTiming": {
        "entrancePreset": "slideUp",
        "viewport": {
          "amount": 0
        },
        "entranceMotion": {
          "transition": {
            "duration": 0.6,
            "delay": 0.08
          }
        }
      }
    },
    "b-medium": {
      "type": "elementBody",
      "level": 5,
      "text": "35mm film · 24 frames · Silver gelatin prints",
      "align": "center",
      "textAlign": "center",
      "width": "hug",
      "marginBottom": "2.5rem"
    }
  },
  "gap": "1rem"
}
