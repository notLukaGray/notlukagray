      "width": "100%",
      "height": "hug",
      "wordWrap": true,
      "motionTiming": {
        "entrancePreset": "slideLeft",
        "viewport": { "amount": 0.3 },
        "entranceMotion": { "transition": { "duration": 0.55 } }
      }
    },
    "d-detail": {
      "type": "elementBody",
      "level": 5,
      "text": "Camera · Lens · Film stock / sensor\nPrinted at — × — cm · Edition of N",
