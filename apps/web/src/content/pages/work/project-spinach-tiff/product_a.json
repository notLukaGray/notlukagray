{
  "type": "contentBlock",
  "flexDirection": "column",
  "id": "product_a",
  "width": ["100%", "88%"],
  "height": ["100vh", "100vh"],
  "align": ["full", "center"],
  "fill": "transparent",
  "zIndex": 0,
  "fixed": true,
  "alignItems": "center",
  "justifyContent": "center",
  "contentHeight": "full",
  "gap": "0.35rem",
  "scrollOpacityRange": {
    "input": [0.6, 0.8],
    "output": [1, 0]
  },
  "elementOrder": ["a-platform", "a-title", "a-logline", "a-stack"],
  "definitions": {
    "a-platform": {
      "type": "elementHeading",
      "variant": "label",
      "text": "iOS / ANDROID / WEB · PRODUCT DESIGN",
      "align": "center",
      "width": "hug",
      "marginBottom": "1rem",
      "motionTiming": {
        "entrancePreset": "fade",
        "viewport": {
          "amount": 0
        },
        "entranceMotion": {
          "transition": {
            "duration": 0.5
          }
        }
      }
    },
    "a-title": {
      "type": "elementHeading",
      "level": 1,
      "text": "Spinach x TIFF",
      "align": "center",
      "width": ["92%", "68%"],
      "wordWrap": true,
      "marginBottom": "1.5rem",
      "motionTiming": {
        "entrancePreset": "slideUp",
        "viewport": {
          "amount": 0
        },
        "entranceMotion": {
          "transition": {
            "duration": 0.6,
            "delay": 0.08
          }
        }
      }
    },
    "a-logline": {
      "type": "elementBody",
      "level": 2,
      "text": "A cinematic parody trailer created for Spinach and shown in association with TIFF. Inspired by the iconic Walt Disney opening, the piece reimagined the familiar castle silhouette as a towering landscape of giant cannabis nugs, complete with sweeping background scenery and fireworks bursting overhead. The result was playful, unexpected, and deliberately tongue-in-cheek, using a universally recognizable film intro to give the brand a bold, theatrical moment on screen.",
      "align": "center",
      "textAlign": "center",
      "width": ["88%", "52%"],
      "wordWrap": true,
      "marginBottom": "2.5rem",
      "motionTiming": {
        "entrancePreset": "slideUp",
        "viewport": {
          "amount": 0
        },
        "entranceMotion": {
          "transition": {
            "duration": 0.5,
            "delay": 0.18
          }
        }
      }
    },
    "a-stack": {
      "type": "elementBody",
      "level": 5,
      "text": "Figma · Prototyping · Design System · Handoff",
      "align": "center",
      "textAlign": "center",
      "width": "hug"
    }
  }
}
