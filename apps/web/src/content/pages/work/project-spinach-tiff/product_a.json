        }
      },
      "display": "flex",
      "flexDirection": "row",
      "flexWrap": "wrap",
      "alignItems": "center",
      "justifyContent": "center",
      "gap": "0.5rem",
      "align": "center",
      "width": ["88%", "60%"]
    }
  }
}
