{
  "type": "contentBlock",
  "flexDirection": "column",
  "id": "product_a",
  "width": ["100%", "88%"],
  "height": ["100vh", "100vh"],
  "align": ["full", "center"],
  "fill": "transparent",
  "zIndex": 0,
  "fixed": true,
  "alignItems": "center",
  "justifyContent": "center",
  "contentHeight": "full",
  "gap": "0.35rem",
  "scrollOpacityRange": {
    "input": [0.6, 0.8],
    "output": [1, 0]
  },
  "elementOrder": ["a-platform", "a-title", "a-logline", "a-stack"],
  "definitions": {
    "a-platform": {
      "type": "elementLink",
      "href": "/work?brand=spinach",
      "external": false,
      "copyType": "heading",
      "level": 6,
      "label": "*Spinach Cannabis*",
      "align": "center",
      "width": "hug",
      "marginBottom": "1rem",
      "fontWeight": 700,
      "motionTiming": {
        "entrancePreset": "fade",
        "viewport": {
          "amount": 0
        },
        "entranceMotion": {
          "transition": {
            "duration": 0.5
          }
        }
      }
    },
    "a-title": {
      "type": "elementHeading",
      "level": 1,
      "text": "Cannabis for Movies",
      "align": "center",
      "width": ["92%", "68%"],
      "maxWidth": "1000px",
      "wordWrap": true,
      "marginBottom": "1.5rem",
      "motionTiming": {
        "entrancePreset": "slideUp",
        "viewport": {
          "amount": 0
        },
        "entranceMotion": {
          "transition": {
            "duration": 0.6,
            "delay": 0.08
          }
        }
      }
    },
    "a-logline": {
      "type": "elementBody",
      "level": 2,
      "text": "A cinematic parody trailer created for **Spinach** to be shown in association with the **Toronto International Film Festival**.",
      "align": "center",
      "textAlign": "center",
      "width": ["88%", "52%"],
      "maxWidth": "600px",
      "wordWrap": true,
      "marginBottom": "2.5rem",
      "motionTiming": {
        "entrancePreset": "slideUp",
        "viewport": {
          "amount": 0
        },
        "entranceMotion": {
          "transition": {
            "duration": 0.5,
            "delay": 0.18
          }
        }
      }
    },
    "a-stack": {
      "type": "elementGroup",
      "section": {
        "elementOrder": ["a-tag-1", "a-tag-2", "a-tag-3", "a-tag-4"],
        "definitions": {
          "a-tag-1": {
            "type": "elementLink",
            "href": "/work?ability=art-direction",
            "external": false,
            "copyType": "body",
            "level": 5,
            "label": "Art Direction",
            "motion": {
              "animate": {
                "backgroundColor": "oklch(from var(--pb-on-secondary) l c h / 0.06)"
              },
              "whileHover": {
                "backgroundColor": "oklch(0.84 0.03 158)"
              }
            },
            "wrapperStyle": {
              "padding": "0.38rem 0.72rem",
              "borderRadius": "999px",
              "background": "oklch(from var(--pb-on-secondary) l c h / 0.06)"
            }
          },
          "a-tag-2": {
            "type": "elementLink",
            "href": "/work?ability=cgi",
            "external": false,
            "copyType": "body",
            "level": 5,
            "label": "CGI",
            "motion": {
              "animate": {
                "backgroundColor": "oklch(from var(--pb-on-secondary) l c h / 0.06)"
              },
              "whileHover": {
                "backgroundColor": "oklch(0.84 0.03 158)"
              }
            },
            "wrapperStyle": {
              "padding": "0.38rem 0.72rem",
              "borderRadius": "999px",
              "background": "oklch(from var(--pb-on-secondary) l c h / 0.06)"
            }
          },
          "a-tag-3": {
            "type": "elementLink",
            "href": "/work?ability=motion-graphics",
            "external": false,
            "copyType": "body",
            "level": 5,
            "label": "Motion Graphics",
            "motion": {
              "animate": {
                "backgroundColor": "oklch(from var(--pb-on-secondary) l c h / 0.06)"
              },
              "whileHover": {
                "backgroundColor": "oklch(0.84 0.03 158)"
              }
            },
            "wrapperStyle": {
              "padding": "0.38rem 0.72rem",
              "borderRadius": "999px",
              "background": "oklch(from var(--pb-on-secondary) l c h / 0.06)"
            }
          },
          "a-tag-4": {
