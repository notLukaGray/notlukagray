{
  "type": "module",
  "contextType": "video",
  "contentSlot": "main",
  "container": {
    "padding": "10px",
    "borderRadius": "20px"
  },
  "behavior": {
    "sleepAfterMs": 3000,
    "sleepFadeMs": 500,
    "controlsTransitionMs": 500,
    "controlsTransitionEasing": "easeOut",
    "transitionEasing": "easeOut",
    "feedbackDurationMs": 100
  },
  "overlayMotion": {
    "initial": {
      "opacity": 0
    },
    "animate": {
      "opacity": 1
    },
    "transition": {
      "duration": 0.5,
      "ease": "easeOut"
    },
    "whileHover": {},
    "whileTap": {
      "scale": 1,
      "opacity": 1
    },
    "whileFocus": {
      "opacity": 1
    }
  },
  "slots": {
    "main": {
      "position": "absolute",
      "inset": "0",
      "zIndex": 0
    },
    "bottomBar": {
      "position": "absolute",
      "bottom": "10px",
      "left": "10px",
      "right": "10px",
      "zIndex": 10,
      "display": "flex",
      "flexDirection": "row",
      "alignItems": "center",
      "justifyContent": "flex-start",
      "height": "44px",
      "gap": "2px",
      "visibleWhen": ["awake"],
      "transformInherit": "disable",
      "slotWrapperGestures": false,
      "wrapperMotion": {
        "whileHover": {
          "opacity": 1
        },
        "whileTap": {
          "opacity": 1
        },
        "whileFocus": {
          "opacity": 1
        }
      },
      "defaultWrapperStyle": {
        "width": "44px",
        "height": "44px",
        "minWidth": "44px",
        "minHeight": "44px"
      },
      "style": {
        "background": "#00000020",
        "borderRadius": "9999px"
      },
      "effects": [
        {
          "type": "glass",
          "bezelType": "convex_squircle",
          "bezelWidth": 24,
          "glassThickness": 20,
          "refractiveIndex": 1.8,
          "blur": 1,
          "scaleRatio": 1,
          "specularOpacity": 0.5,
          "specularSaturation": 25,
          "magnifyingScale": 0.5,
          "dropShadow": true
        }
      ],
      "section": {
        "elementOrder": ["left-controls", "seek-wrap", "right-controls"],
        "definitions": {
          "left-controls": {
            "type": "elementGroup",
            "width": "88px",
            "height": "44px",
            "display": "flex",
            "flexDirection": "row",
            "alignItems": "center",
            "padding": "0 0 0 4px",
            "gap": "0px",
            "wrapperStyle": {
              "position": "relative",
              "zIndex": 1
            },
            "section": {
              "elementOrder": ["ui-play", "ui-pause", "mute-btn", "unmute-btn"],
              "definitions": {
                "ui-play": {
                  "preset": "video-controls-play-bar",
                  "action": "assetTogglePlay",
                  "showWhen": "assetPaused",
                  "wrapperStyle": {
                    "transform": "translateY(1px)"
                  }
                },
                "ui-pause": {
                  "preset": "video-controls-pause-bar",
                  "action": "assetTogglePlay",
                  "showWhen": "assetPlaying",
                  "wrapperStyle": {
                    "transform": "translateY(1px)"
                  }
                },
                "mute-btn": {
                  "preset": "video-controls-mute-bar",
                  "action": "assetMute",
                  "showWhen": "assetUnmuted",
                  "wrapperStyle": {
                    "transform": "translateY(1px)"
                  }
                },
                "unmute-btn": {
                  "preset": "video-controls-unmute-bar",
                  "action": "assetMute",
                  "showWhen": "assetMuted",
                  "wrapperStyle": {
                    "transform": "translateY(1px)"
                  }
                }
              }
            }
          },
          "seek-wrap": {
            "type": "elementGroup",
            "flex": "1",
            "height": "44px",
            "display": "flex",
            "flexDirection": "row",
            "alignItems": "center",
            "justifyContent": "center",
            "padding": "0 16px 0 8px",
            "wrapperStyle": {
              "position": "relative",
              "zIndex": 1
            },
            "section": {
              "elementOrder": ["seek"],
              "definitions": {
                "seek": {
                  "preset": "video-controls-seek",
                  "wrapperStyle": {
                    "width": "100%",
                    "height": "20px"
                  },
                  "width": "100%",
                  "height": "20px",
                  "style": {
                    "trackColor": "rgba(255,255,255,0.38)",
                    "fillColor": "#FFFFFF",
                    "trackHeight": "3px",
                    "thumbSize": "10px"
                  }
                }
              }
            }
          },
          "right-controls": {
            "type": "elementGroup",
            "width": "hug",
            "display": "flex",
            "flexDirection": "row",
            "alignItems": "center",
            "justifyContent": "flex-end",
            "gap": "4px",
            "wrapperStyle": {
              "position": "relative",
              "zIndex": 1
            },
            "section": {
              "elementOrder": ["fullscreen", "minimize"],
              "definitions": {
                "fullscreen": {
                  "preset": "video-controls-fullscreen-bar",
                  "action": "videoFullscreen",
                  "showWhen": "videoContained"
                },
                "minimize": {
                  "preset": "video-controls-minimize-bar",
                  "action": "videoFullscreen",
                  "showWhen": "videoFullscreen"
                }
              }
            }
          }
        }
      }
    }
  }
}
