{
  "type": "sectionColumn",
  "id": "nav",
  "ariaLabel": "FPO: Main navigation",
  "fixed": true,
  "fixedPosition": "top",
  "fixedOffset": "0px",
  "zIndex": 100,

  "width": "100%",
  "contentWidth": "min(90%,600px)",
  "height": "hug",
  "align": "center",

  "fill": "#00000020",
  "borderRadius": "0 0 30px 30px",
  "effects": [
    {
      "type": "glass",
      "bezelType": "convex_squircle",
      "bezelWidth": 24,
      "glassThickness": 20,
      "refractiveIndex": 1.8,
      "blur": 1,
      "scaleRatio": 1,
      "specularOpacity": 0.5,
      "specularSaturation": 5,
      "magnifyingScale": 0.5,
      "dropShadow": true
    }
  ],

  "marginTop": ".5rem",
  "marginRight": "1rem",
  "marginBottom": ".5rem",
  "marginLeft": "1rem",

  "elementOrder": ["work", "teaching", "logo", "research", "profile"],
  "columnAssignments": {
    "work": 0,
    "teaching": 1,
    "logo": 2,
    "research": 3,
    "profile": 4
  },
  "columnGaps": "auto",
  "columns": 5,

  "definitions": {
    "work": {
      "preset": "nav-link-default",
      "type": "elementLink",
      "id": "work",
      "label": "Work",
      "href": "/work"
    },
    "teaching": {
      "preset": "nav-link-default",
      "type": "elementLink",
      "id": "teaching",
      "label": "Teaching",
      "href": "/teaching"
    },
    "logo": {
      "preset": "logo-default"
    },
    "research": {
      "preset": "nav-link-default",
      "type": "elementLink",
      "id": "research",
      "label": "Research",
      "href": "/research"
    },
    "profile": {
      "preset": "nav-link-default",
      "type": "elementLink",
      "id": "profile",
      "label": "Profile",
      "href": "/profile"
    }
  }
}
