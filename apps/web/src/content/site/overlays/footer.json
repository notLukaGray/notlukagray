{
  "type": "sectionColumn",
  "id": "footer",
  "ariaLabel": "FPO: Site footer",
  "elementOrder": ["linkedin", "instagram", "dribbble", "artstation", "copyright"],
  "columns": 5,
  "columnAssignments": {
    "linkedin": 0,
    "instagram": 1,
    "dribbble": 2,
    "artstation": 3,
    "copyright": 4
  },
  "fixed": true,
  "fixedPosition": "bottom",
  "fixedOffset": "0px",
  "zIndex": 200,
  "fill": "oklch(from var(--pb-secondary) l c h / 0.5)",
