{
  "name": "notlukagray",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "tools/*"
  ],
  "scripts": {
    "dev": "concurrently -n web,tools -c cyan,magenta \"npm run web:dev\" \"npm run dev:tools\"",
    "build": "npm run build --workspace @notlukagray/web",
    "generate-protected-slugs": "npm run generate-protected-slugs --workspace @notlukagray/web",
    "start": "npm run start --workspace @notlukagray/web",
    "check": "npm run type-check && npm run lint && npm run format:check && npm run validate-pages && npm run validate-content",
    "fix": "npm run lint:fix && npm run format",
    "type-check": "npm run type-check --workspaces --if-present",
    "lint": "eslint . --max-warnings 0",
    "lint:boundaries": "eslint packages/core/src/internal packages/runtime-react/src/page-builder/elements apps/web/src/core apps/web/src/app/layout.tsx --max-warnings 0 && tsx scripts/check-boundaries.ts",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "prepare": "command -v husky >/dev/null 2>&1 && husky || true",
    "prepare:commit": "bash scripts/prepare-commit.sh",
    "pb-cli": "tsx tools/pb-cli/src/index.ts",
    "contracts:generate-schemas": "npm run generate-schemas --workspace @pb/contracts",
    "list-assets": "npm run list-assets --workspace @notlukagray/web",
    "generate-json-schemas": "npm run generate-json-schemas --workspace @notlukagray/web",
    "validate-pages": "npm run validate-pages --workspace @notlukagray/web",
    "validate-content": "tsx scripts/validate-all-pages.ts",
    "audit-section-key-collisions": "tsx scripts/audit-section-key-collisions.ts",
    "check:route-budgets": "tsx scripts/check-route-budgets.ts",
    "dev:tools": "npm -w tools/dev-hls-server run start",
    "dev:hls": "npm run dev:tools",
    "web:dev": "npm run dev --workspace @notlukagray/web",
    "web:build": "npm run build --workspace @notlukagray/web",
    "web:start": "npm run start --workspace @notlukagray/web",
    "test": "vitest run",
    "test:watch": "vitest",
    "knip": "knip",
    "knip:exports": "knip --include exports,types,nsExports,nsTypes,enumMembers,namespaceMembers,duplicates"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@pb/contracts": "1.0.0",
    "@pb/core": "1.0.0",
    "next": "^16.2.4",
    "zod": "4.4.2"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.10"
    }
  },
  "browserslist": [
    "defaults",
    "not dead"
  ],
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/culori": "^4.0.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "knip": "^6.10.0",
    "lint-staged": "^16.4.0",
    "patch-package": "^8.0.1",
    "postcss": "^8.5.13",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "typescript": "6.0.3",
    "vitest": "^4.1.5"
  }
}
