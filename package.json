{
  "name": "notlukagray",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run generate-json-schemas && next dev",
    "build": "npm run generate-page-manifest && npm run generate-protected-slugs && next build",
    "generate-page-manifest": "tsx scripts/generate-page-manifest.ts",
    "generate-protected-slugs": "tsx scripts/generate-protected-slugs.ts",
    "start": "next start",
    "check": "npm run type-check && npm run lint && npm run format:check && npm run validate-pages",
    "fix": "npm run lint:fix && npm run format",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "postinstall": "node scripts/patch-eslint-plugin-react-eslint10.mjs",
    "prepare": "husky",
    "prepare:commit": "bash scripts/prepare-commit.sh",
    "list-assets": "tsx scripts/list-page-builder-assets.ts",
    "generate-json-schemas": "tsx scripts/generate-json-schemas.ts && prettier --write src/content/schemas/page-builder.schema.json src/content/schemas/definition-block.schema.json src/content/schemas/definitions-file.schema.json src/content/schemas/module.schema.json",
    "validate-pages": "tsx scripts/validate-pages.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@nkzw/liquid-glass": "^1.3.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "@rive-app/react-canvas": "^4.27.2",
    "framer-motion": "^12.35.1",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "postprocessing": "^6.38.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "three": "^0.183.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "browserslist": [
    "defaults",
    "not dead"
  ],
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^20.19.37",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "chokidar": "^4.0.3",
    "eslint": "^10.0.3",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "happy-dom": "^20.8.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vitest": "^4.0.18"
  }
}
