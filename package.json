{
  "name": "notlukagray",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "tools/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @notlukagray/web",
    "build": "npm run build --workspace @notlukagray/web",
    "generate-protected-slugs": "npm run generate-protected-slugs --workspace @notlukagray/web",
    "start": "npm run start --workspace @notlukagray/web",
    "check": "npm run type-check && npm run lint && npm run format:check && npm run validate-pages",
    "fix": "npm run lint:fix && npm run format",
    "type-check": "npm run type-check --workspaces --if-present",
    "lint": "eslint . --max-warnings 0",
    "lint:boundaries": "eslint packages/core/src/internal packages/runtime-react/src/page-builder/elements apps/web/src/core apps/web/src/app/layout.tsx --max-warnings 0 && tsx scripts/check-boundaries.ts",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "postinstall": "node scripts/patch-eslint-plugin-react-eslint10.mjs",
    "prepare": "husky || true",
    "prepare:commit": "bash scripts/prepare-commit.sh",
    "pb-cli": "tsx tools/pb-cli/src/index.ts",
    "contracts:generate-schemas": "npm run generate-schemas --workspace @pb/contracts",
    "list-assets": "npm run list-assets --workspace @notlukagray/web",
    "generate-json-schemas": "npm run generate-json-schemas --workspace @notlukagray/web",
    "validate-pages": "npm run validate-pages --workspace @notlukagray/web",
    "check:route-budgets": "tsx scripts/check-route-budgets.ts",
    "web:dev": "npm run dev --workspace @notlukagray/web",
    "web:build": "npm run build --workspace @notlukagray/web",
    "web:start": "npm run start --workspace @notlukagray/web",
    "test": "vitest run",
    "test:watch": "vitest",
    "knip": "knip",
    "knip:exports": "knip --include exports,types,nsExports,nsTypes,enumMembers,namespaceMembers,duplicates"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@pb/contracts": "1.0.0",
    "@pb/core": "1.0.0",
    "@pb/extensions": "1.0.0",
    "@pb/runtime-react": "1.0.0",
    "@pb/sdk": "1.0.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "@rive-app/react-canvas": "^4.27.2",
    "culori": "^4.0.2",
    "framer-motion": "^12.35.1",
    "highlight.js": "^11.11.1",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "three": "^0.183.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "browserslist": [
    "defaults",
    "not dead"
  ],
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/culori": "^4.0.1",
    "@types/node": "^20.19.37",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "chokidar": "^4.0.3",
    "eslint": "^10.0.3",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "happy-dom": "^20.8.3",
    "husky": "^9.1.7",
    "knip": "^6.1.0",
    "lint-staged": "^16.3.2",
    "patch-package": "^8.0.1",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vitest": "^4.0.18"
  }
}
