{
  "type": "sectionColumn",
  "id": "rtl_c",
  "width": ["100%", "92%"],
  "height": "hug",
  "align": ["full", "center"],
  "fill": "#0000000a",
  "borderRadius": ["1.25rem", "2rem"],
  "marginBottom": ["1.5rem", "2.5rem"],
  "columns": { "mobile": 1, "desktop": 2 },
  "columnWidths": { "mobile": [1], "desktop": [1, 1] },
