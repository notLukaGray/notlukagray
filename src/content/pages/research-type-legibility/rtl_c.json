  "columnStyles": {
    "mobile": [{ "padding": "1.25rem", "gap": "1rem" }],
    "desktop": [
      { "padding": "1.5rem", "gap": "1rem" },
      { "padding": "1.5rem", "gap": "1rem" }
    ]
  },
  "itemStyles": {
    "desktop": {
      "c-spec-a": { "borderRadius": "1rem", "fill": "#0000000a", "padding": "0.4rem" },
      "c-spec-b": { "borderRadius": "1rem", "fill": "#0000000a", "padding": "0.4rem" }
    }
  },
  "columnAssignments": {
    "mobile": { "c-label": 0, "c-finding": 0, "c-spec-a": 0, "c-spec-b": 0 },
    "desktop": { "c-label": 0, "c-finding": 0, "c-spec-a": 0, "c-spec-b": 1 }
  },
  "columnSpan": {
