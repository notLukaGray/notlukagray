      "width": "hug",
      "height": "hug"
    },
    "c-finding": {
      "type": "elementBody",
      "level": 3,
      "text": "The interaction between line length and line-height proved to be the most predictive combination — more significant than either variable alone. Size gains plateau after 18px for desktop reading in standard ambient light.",
      "align": "left",
      "textAlign": "left",
      "width": "100%",
      "height": "hug",
      "wordWrap": true,
      "marginBottom": "0.5rem",
      "motionTiming": {
        "entrancePreset": "fade",
        "viewport": { "amount": 0.2 },
        "entranceMotion": { "transition": { "duration": 0.5, "delay": 0 } }
      }
    },
    "c-spec-a": {
      "type": "elementImage",
      "src": "research/research-type-legibility/specimen-optimal.webp",
      "alt": "Optimal condition: 16px, weight 400, line-height 1.6, 65 char line",
      "objectFit": "contain",
      "width": "100%",
      "height": ["12rem", "20rem"],
      "borderRadius": "0.75rem",
      "align": "center",
      "motionTiming": {
        "entrancePreset": "fade",
        "viewport": { "amount": 0.2 },
        "entranceMotion": { "transition": { "duration": 0.4, "delay": 0.08 } }
      }
    },
    "c-spec-b": {
      "type": "elementImage",
      "src": "research/research-type-legibility/specimen-poor.webp",
      "alt": "Poor condition: 13px, weight 300, line-height 1.2, 90 char line",
      "objectFit": "contain",
      "width": "100%",
      "height": ["12rem", "20rem"],
      "borderRadius": "0.75rem",
      "align": "center",
      "motionTiming": {
        "entrancePreset": "fade",
        "viewport": { "amount": 0.2 },
        "entranceMotion": { "transition": { "duration": 0.4, "delay": 0.08 } }
      }
    }
  }
