{
  "type": "sectionColumn",
  "id": "lenero_section_d",
  "width": ["100%", "88%"],
  "height": "hug",
  "align": ["full", "center"],
  "fill": "#00000000",
  "scrollSpeed": 0.85,
  "marginBottom": ["1.5rem", "2.5rem"],
  "columns": { "mobile": 1, "desktop": 1 },
  "columnWidths": { "mobile": [1], "desktop": [1] },
  "columnGaps": { "mobile": "0", "desktop": "0" },
  "columnStyles": {
    "mobile": [{ "padding": "0", "gap": "0" }],
    "desktop": [{ "padding": "0", "gap": "0" }]
  },
  "columnAssignments": {
    "mobile": { "d-portrait": 0, "d-quote": 0, "d-attribution": 0 },
    "desktop": { "d-portrait": 0, "d-quote": 0, "d-attribution": 0 }
  },
  "itemStyles": {
    "mobile": {
      "d-quote": { "padding": "1.5rem 0 0.5rem" },
      "d-attribution": { "padding": "0 0 0.25rem" }
    },
    "desktop": {
      "d-quote": { "padding": "3rem 0 1rem" },
      "d-attribution": { "padding": "0 0 0.5rem" }
    }
  },
  "elementOrder": ["d-portrait", "d-quote", "d-attribution"],
  "definitions": {
    "d-portrait": {
      "type": "elementImage",
      "src": "work/lenero/lenero-alex-portrait.webp",
      "alt": "Alex Lopez — settled and at rest in the forest he has tended his whole life",
      "objectFit": "cover",
      "objectPosition": "50% 20%",
      "width": "100%",
      "height": ["72vw", "68vh"],
      "constraints": [{ "maxHeight": "30rem" }, { "maxHeight": "44rem" }],
      "borderRadius": ["1.25rem", "1.5rem"],
      "motionTiming": {
        "entrancePreset": "fade",
        "viewport": { "amount": 0.1 },
        "entranceMotion": { "transition": { "duration": 0.8 } }
      }
    },
    "d-quote": {
      "type": "elementBody",
      "level": 2,
      "text": "\"We're not going to save the world. But we're saving a piece of it.\"",
      "align": "center",
      "textAlign": "center",
      "width": ["100%", "58%"],
      "height": "hug",
      "wordWrap": true,
      "motionTiming": {
        "entrancePreset": "fade",
        "viewport": { "amount": 0.2 },
        "entranceMotion": { "transition": { "duration": 0.7 } }
      }
    },
    "d-attribution": {
      "type": "elementBody",
      "level": 6,
      "text": "— Alex Lopez, Las Trampas, NM",
      "align": "center",
      "textAlign": "center",
      "width": "100%",
      "height": "hug",
      "motionTiming": {
        "entrancePreset": "fade",
        "viewport": { "amount": 0.2 },
        "entranceMotion": { "transition": { "duration": 0.5, "delay": 0.12 } }
      }
    }
  }
}
