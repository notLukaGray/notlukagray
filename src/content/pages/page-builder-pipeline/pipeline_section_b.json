{
  "type": "sectionColumn",
  "id": "pipeline_section_b",
  "width": ["100%", "92%"],
  "contentWidth": ["100%", "min(92%, 72rem)"],
  "height": "hug",
  "marginTop": ["1.5rem", "3rem"],
  "marginBottom": ["1.5rem", "3rem"],
  "align": "center",
  "fill": "#00000088",
  "borderRadius": ["1.25rem", "2rem"],
  "effects": [{ "type": "backdropBlur", "amount": "20px" }],
  "columns": { "mobile": 1, "desktop": 2 },
  "columnWidths": { "mobile": [1], "desktop": [1.3, 1] },
  "columnGaps": { "mobile": "1rem", "desktop": "2rem" },
  "columnStyles": {
    "mobile": [{ "padding": "1rem", "gap": "1rem" }],
    "desktop": [
      { "padding": "1.5rem 1.75rem", "gap": "1rem", "alignY": "top" },
      { "padding": "1.5rem 1.75rem", "gap": "1rem", "alignY": "center" }
    ]
  },
  "itemStyles": {
    "mobile": {
      "principle-quote": { "padding": "1rem", "fill": "#ffffff0c", "borderRadius": "1rem" }
    },
    "desktop": {
      "principle-quote": {
        "padding": "1.25rem 1.5rem",
        "fill": "#d2ff7a12",
        "borderRadius": "1rem",
        "alignY": "center"
      }
    }
  },
  "columnAssignments": {
    "mobile": { "principle-head": 0, "principle-body": 0, "principle-quote": 0 },
    "desktop": { "principle-head": 0, "principle-body": 0, "principle-quote": 1 }
  },
  "elementOrder": {
    "mobile": ["principle-head", "principle-body", "principle-quote"],
    "desktop": ["principle-head", "principle-body", "principle-quote"]
  },
  "definitions": {
    "principle-head": {
      "type": "elementHeading",
      "level": 2,
      "text": "Structure vs environment",
      "width": "100%",
      "align": "left",
      "textAlign": "left",
      "wordWrap": true,
      "motionTiming": { "entrancePreset": "fade" }
    },
    "principle-body": {
      "type": "elementRichText",
      "content": "**Load** and **Expand** only touch structure: page JSON, definitions, presets, section order, element refs, trigger payload refs. They’re pure and sync. **Resolve** is where environment shows up: `assetBase`, trigger payload URLs, 3D assets (inline or proxy). **Render** then mounts a resolved page with no client-side resolution.\n\nSo: new pages are just new JSON (and optional section files). One dynamic route and one `getPage(slug)` serve everything.",
      "level": 2,
      "width": "100%",
      "align": "left",
      "textAlign": "left",
      "wordWrap": true,
      "motionTiming": {
        "entrancePreset": "slideUp",
        "entranceMotion": { "transition": { "delay": 0.08 } }
      }
    },
    "principle-quote": {
      "type": "elementBody",
      "level": 2,
      "text": "You add a page by authoring JSON, not by adding a new React route. One route, one pipeline, many pages.",
      "width": "100%",
      "align": "left",
      "textAlign": "left",
      "wordWrap": true,
      "motionTiming": {
        "entrancePreset": "slideUp",
        "entranceMotion": { "transition": { "delay": 0.18 } }
      }
    }
  }
}
