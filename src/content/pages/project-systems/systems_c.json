          "amount": 0.2
        },
        "entranceMotion": {
          "transition": {
            "duration": 0.4,
            "delay": 0
          }
        }
      }
    },
    "c-color": {
      "type": "elementRichText",
      "content": "### Color\n\n**Primitives**\n\n- `--ink` #0a0a0a\n- `--paper` #f5f0e8\n- `--accent` #d2ff7a\n- `--signal` #f000b8\n\n**Semantic**\n\n- `--fg-primary` ink/90\n- `--fg-secondary` ink/50\n- `--surface-1` ink/06\n- `--surface-2` ink/10\n- `--border` ink/12",
      "level": 5,
      "align": "left",
      "width": "100%",
      "height": "hug",
