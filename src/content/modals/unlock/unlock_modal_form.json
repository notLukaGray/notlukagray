{
  "type": "formBlock",
  "id": "unlock_modal_form",
  "ariaLabel": "Unlock form",
  "width": "100%",
  "height": "hug",
  "align": "center",
  "fill": "transparent",
  "contentWidth": "full",
  "action": "unlock",
  "method": "post",
  "actionPayload": {
    "redirect": "/"
  },
  "fields": [
    {
      "type": "formField",
      "fieldType": "password",
      "name": "password",
      "label": "Password",
      "placeholder": "Password",
      "required": true,
      "level": 3
    },
    {
      "type": "formField",
      "fieldType": "submit",
      "label": "Unlock",
      "loadingText": "Checking…",
      "level": 2,
      "inputClassName": "font-semibold"
    }
  ]
}
