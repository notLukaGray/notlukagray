{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Effect definitions for sections (contentBlock, divider). Referenced from builder-schema.json / section-blocks.json.",
  "version": "1",
  "effects": [
    {
      "type": "backdropBlur",
      "label": "Backdrop blur",
      "description": "Blurs the content behind the section (e.g. video or background).",
      "props": [
        {
          "name": "amount",
          "type": "string",
          "required": false,
          "description": "CSS blur radius, e.g. 8px, 12px, 24px. Default: 12px."
        }
      ]
    },
    {
      "type": "glass",
      "label": "Glass",
      "description": "Applies a glass surface treatment tuned for Figma GLASS effects.",
      "props": [
        {
          "name": "frost",
          "type": "string",
          "required": false,
          "description": "Backdrop blur amount, e.g. 12px, 16px, 24px. Default: 16px."
        },
        {
          "name": "lightIntensity",
          "type": "number",
          "required": false,
          "description": "Specular highlight intensity between 0 and 1. Default: 0.35."
        },
        {
          "name": "lightAngle",
          "type": "number",
          "required": false,
          "description": "Light direction angle in degrees."
        },
        {
          "name": "refraction",
          "type": "number",
          "required": false,
          "description": "Refraction strength between 0 and 1."
        },
        {
          "name": "depth",
          "type": "number",
          "required": false,
          "description": "Perceived glass depth (>= 1)."
        },
        {
          "name": "dispersion",
          "type": "number",
          "required": false,
          "description": "Chromatic dispersion amount between 0 and 1."
        },
        {
          "name": "mode",
          "type": "string",
          "required": false,
          "description": "Liquid glass mode: standard, polar, prominent, or shader."
        }
      ]
    },
    {
      "type": "dropShadow",
      "label": "Drop shadow",
      "description": "Adds a shadow behind the section.",
      "props": [
        {
          "name": "x",
          "type": "string",
          "required": false,
          "description": "Horizontal offset, e.g. 0px. Default: 0px."
        },
        {
          "name": "y",
          "type": "string",
          "required": false,
          "description": "Vertical offset, e.g. 4px. Default: 4px."
        },
        {
          "name": "blur",
          "type": "string",
          "required": false,
          "description": "Blur radius, e.g. 24px. Default: 24px."
        },
        {
          "name": "spread",
          "type": "string",
          "required": false,
          "description": "Spread radius, e.g. 0px. Default: none."
        },
        {
          "name": "color",
          "type": "string",
          "required": false,
          "description": "Shadow color, e.g. rgba(0,0,0,0.15). Default: rgba(0,0,0,0.15)."
        }
      ]
    },
    {
      "type": "innerShadow",
      "label": "Inner shadow",
      "description": "Adds an inset shadow inside the section.",
      "props": [
        {
          "name": "x",
          "type": "string",
          "required": false,
          "description": "Horizontal offset, e.g. 0px. Default: 0px."
        },
        {
          "name": "y",
          "type": "string",
          "required": false,
          "description": "Vertical offset, e.g. 4px. Default: 4px."
        },
        {
          "name": "blur",
          "type": "string",
          "required": false,
          "description": "Blur radius, e.g. 24px. Default: 24px."
        },
        {
          "name": "spread",
          "type": "string",
          "required": false,
          "description": "Spread radius, e.g. 0px. Default: none."
        },
        {
          "name": "color",
          "type": "string",
          "required": false,
          "description": "Shadow color, e.g. rgba(0,0,0,0.15). Default: rgba(0,0,0,0.15)."
        }
      ]
    },
    {
      "type": "glow",
      "label": "Glow",
      "description": "Adds a glowing effect around the section.",
      "props": [
        {
          "name": "blur",
          "type": "string",
          "required": false,
          "description": "Blur radius, e.g. 20px. Default: 20px."
        },
        {
          "name": "spread",
          "type": "string",
          "required": false,
          "description": "Spread radius, e.g. 0px. Default: 0px."
        },
        {
          "name": "color",
          "type": "string",
          "required": false,
          "description": "Glow color, e.g. rgba(0,0,0,0.5). Default: rgba(0,0,0,0.5)."
        }
      ]
    },
    {
      "type": "opacity",
      "label": "Opacity",
      "description": "Sets the opacity of the section.",
      "props": [
        {
          "name": "value",
          "type": "number",
          "required": false,
          "description": "Opacity value between 0 and 1. Default: 1."
        }
      ]
    },
    {
      "type": "blur",
      "label": "Blur",
      "description": "Blurs the section itself.",
      "props": [
        {
          "name": "amount",
          "type": "string",
          "required": false,
          "description": "CSS blur radius, e.g. 4px. Default: 4px."
        }
      ]
    },
    {
      "type": "brightness",
      "label": "Brightness",
      "description": "Adjusts the brightness of the section.",
      "props": [
        {
          "name": "value",
          "type": "number",
          "required": false,
          "description": "Brightness multiplier (1 = normal, >1 = brighter, <1 = darker). Default: 1."
        }
      ]
    },
    {
      "type": "contrast",
      "label": "Contrast",
      "description": "Adjusts the contrast of the section.",
      "props": [
        {
          "name": "value",
          "type": "number",
          "required": false,
          "description": "Contrast multiplier (1 = normal, >1 = more contrast, <1 = less contrast). Default: 1."
        }
      ]
    },
    {
      "type": "saturate",
      "label": "Saturate",
      "description": "Adjusts the saturation of the section.",
      "props": [
        {
          "name": "value",
          "type": "number",
          "required": false,
          "description": "Saturation multiplier (1 = normal, >1 = more saturated, <1 = less saturated). Default: 1."
        }
      ]
    },
    {
      "type": "grayscale",
      "label": "Grayscale",
      "description": "Converts the section to grayscale.",
      "props": [
        {
          "name": "value",
          "type": "number",
          "required": false,
          "description": "Grayscale amount (0 = full color, 1 = full grayscale). Default: 0."
        }
      ]
    },
    {
      "type": "sepia",
      "label": "Sepia",
      "description": "Applies a sepia tone to the section.",
      "props": [
        {
          "name": "value",
          "type": "number",
          "required": false,
          "description": "Sepia amount (0 = no sepia, 1 = full sepia). Default: 0."
        }
      ]
    }
  ]
}
